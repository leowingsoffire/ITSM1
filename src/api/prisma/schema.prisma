generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Teams ───────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(AGENT)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  teamId String? @map("team_id")
  team   Team?   @relation(fields: [teamId], references: [id])

  assignedIncidents  Incident[]       @relation("AssignedAgent")
  createdIncidents   Incident[]       @relation("CreatedBy")
  serviceRequests    ServiceRequest[]
  comments           Comment[]
  knowledgeArticles  KnowledgeArticle[]
  assignedProblems   Problem[]        @relation("ProblemAssigned")
  createdProblems    Problem[]        @relation("ProblemCreatedBy")
  requestedChanges   ChangeRequest[]  @relation("ChangeRequester")
  assignedChanges    ChangeRequest[]  @relation("ChangeAssigned")
  approvals          Approval[]
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@map("users")
}

enum UserRole {
  ADMIN
  AGENT
  MANAGER
  END_USER
}

model Team {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  members   User[]
  incidents Incident[]
  problems  Problem[]
  changes   ChangeRequest[]

  @@map("teams")
}

// ─── Incidents ───────────────────────────────────────────────

model Incident {
  id          String           @id @default(uuid())
  number      String           @unique
  title       String
  description String
  status      IncidentStatus   @default(NEW)
  priority    Priority         @default(MEDIUM)
  impact      Impact           @default(MEDIUM)
  urgency     Urgency          @default(MEDIUM)
  category    String?
  subcategory String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  resolvedAt  DateTime?        @map("resolved_at")
  closedAt    DateTime?        @map("closed_at")
  slaBreached Boolean          @default(false) @map("sla_breached")

  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("AssignedAgent", fields: [assignedToId], references: [id])

  assignedTeamId String? @map("assigned_team_id")
  assignedTeam   Team?   @relation(fields: [assignedTeamId], references: [id])

  createdById String @map("created_by_id")
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  relatedAssetId String? @map("related_asset_id")
  relatedAsset   Asset?  @relation(fields: [relatedAssetId], references: [id])

  problemId String? @map("problem_id")
  problem   Problem? @relation(fields: [problemId], references: [id])

  changeRequestId String? @map("change_request_id")
  changeRequest   ChangeRequest? @relation(fields: [changeRequestId], references: [id])

  comments Comment[]

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([category])
  @@index([createdById])
  @@index([assignedTeamId])
  @@index([slaBreached])
  @@index([problemId])
  @@index([changeRequestId])
  @@map("incidents")
}

enum IncidentStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  CANCELLED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

enum Urgency {
  HIGH
  MEDIUM
  LOW
}

// ─── Service Requests ────────────────────────────────────────

model ServiceRequest {
  id          String               @id @default(uuid())
  number      String               @unique
  title       String
  description String
  status      ServiceRequestStatus @default(SUBMITTED)
  priority    Priority             @default(MEDIUM)
  category    String?
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  fulfilledAt DateTime?            @map("fulfilled_at")

  requesterId String @map("requester_id")
  requester   User   @relation(fields: [requesterId], references: [id])

  comments Comment[]

  @@index([status])
  @@index([requesterId])
  @@index([priority])
  @@map("service_requests")
}

enum ServiceRequestStatus {
  SUBMITTED
  APPROVED
  IN_PROGRESS
  FULFILLED
  REJECTED
  CANCELLED
}

// ─── Assets / CMDB ───────────────────────────────────────────

model Asset {
  id           String      @id @default(uuid())
  assetTag     String      @unique @map("asset_tag")
  name         String
  type         AssetType
  status       AssetStatus @default(ACTIVE)
  manufacturer String?
  model        String?
  serialNumber String?     @map("serial_number")
  location     String?
  purchaseDate DateTime?   @map("purchase_date")
  warrantyEnd  DateTime?   @map("warranty_end")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  incidents Incident[]

  @@index([assetTag])
  @@index([type])
  @@index([status])
  @@map("assets")
}

enum AssetType {
  SERVER
  WORKSTATION
  LAPTOP
  NETWORK_DEVICE
  PRINTER
  MOBILE_DEVICE
  SOFTWARE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  RETIRED
  MAINTENANCE
}

// ─── Knowledge Base ──────────────────────────────────────────

model KnowledgeArticle {
  id          String                 @id @default(uuid())
  title       String
  content     String
  category    String?
  tags        String?
  status      KnowledgeArticleStatus @default(DRAFT)
  viewCount   Int                    @default(0) @map("view_count")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  publishedAt DateTime?              @map("published_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([status])
  @@index([authorId])
  @@map("knowledge_articles")
}

enum KnowledgeArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Comments ────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  content   String
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])

  incidentId       String?         @map("incident_id")
  incident         Incident?       @relation(fields: [incidentId], references: [id])
  serviceRequestId String?         @map("service_request_id")
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
  changeRequestId  String?         @map("change_request_id")
  changeRequest    ChangeRequest?  @relation(fields: [changeRequestId], references: [id])
  problemId        String?         @map("problem_id")
  problem          Problem?        @relation(fields: [problemId], references: [id])

  @@index([incidentId])
  @@index([serviceRequestId])
  @@index([changeRequestId])
  @@index([problemId])
  @@map("comments")
}

// ─── SLA Policies ────────────────────────────────────────────

model SlaPolicy {
  id                 String   @id @default(uuid())
  name               String   @unique
  description        String?
  responseTimeMinutes Int     @map("response_time_minutes")
  resolutionTimeMinutes Int   @map("resolution_time_minutes")
  priority           Priority
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([priority])
  @@map("sla_policies")
}

// ─── Change Management (ITIL) ────────────────────────────────

model ChangeRequest {
  id              String             @id @default(uuid())
  number          String             @unique
  title           String
  description     String
  type            ChangeType         @default(NORMAL)
  status          ChangeStatus       @default(NEW)
  priority        Priority           @default(MEDIUM)
  risk            ChangeRisk         @default(MEDIUM)
  impact          Impact             @default(MEDIUM)
  category        String?
  reason          String?
  implementationPlan String?         @map("implementation_plan")
  backoutPlan     String?            @map("backout_plan")
  testPlan        String?            @map("test_plan")
  scheduledStart  DateTime?          @map("scheduled_start")
  scheduledEnd    DateTime?          @map("scheduled_end")
  actualStart     DateTime?          @map("actual_start")
  actualEnd       DateTime?          @map("actual_end")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  closedAt        DateTime?          @map("closed_at")

  requesterId     String             @map("requester_id")
  requester       User               @relation("ChangeRequester", fields: [requesterId], references: [id])

  assignedToId    String?            @map("assigned_to_id")
  assignedTo      User?              @relation("ChangeAssigned", fields: [assignedToId], references: [id])

  assignedTeamId  String?            @map("assigned_team_id")
  assignedTeam    Team?              @relation(fields: [assignedTeamId], references: [id])

  incidents       Incident[]
  approvals       Approval[]
  comments        Comment[]

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([requesterId])
  @@index([assignedToId])
  @@index([scheduledStart])
  @@map("change_requests")
}

enum ChangeType {
  STANDARD
  NORMAL
  EMERGENCY
}

enum ChangeStatus {
  NEW
  PLANNING
  AWAITING_APPROVAL
  APPROVED
  SCHEDULED
  IMPLEMENTING
  COMPLETED
  FAILED
  CANCELLED
}

enum ChangeRisk {
  HIGH
  MEDIUM
  LOW
}

// ─── Problem Management (ITIL) ──────────────────────────────

model Problem {
  id             String         @id @default(uuid())
  number         String         @unique
  title          String
  description    String
  status         ProblemStatus  @default(NEW)
  priority       Priority       @default(MEDIUM)
  impact         Impact         @default(MEDIUM)
  category       String?
  rootCause      String?        @map("root_cause")
  workaround     String?
  isKnownError   Boolean        @default(false) @map("is_known_error")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  resolvedAt     DateTime?      @map("resolved_at")
  closedAt       DateTime?      @map("closed_at")

  assignedToId   String?        @map("assigned_to_id")
  assignedTo     User?          @relation("ProblemAssigned", fields: [assignedToId], references: [id])

  assignedTeamId String?        @map("assigned_team_id")
  assignedTeam   Team?          @relation(fields: [assignedTeamId], references: [id])

  createdById    String         @map("created_by_id")
  createdBy      User           @relation("ProblemCreatedBy", fields: [createdById], references: [id])

  incidents      Incident[]
  comments       Comment[]

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([isKnownError])
  @@index([createdById])
  @@map("problems")
}

enum ProblemStatus {
  NEW
  INVESTIGATING
  ROOT_CAUSE_IDENTIFIED
  KNOWN_ERROR
  RESOLVED
  CLOSED
}

// ─── Approvals ───────────────────────────────────────────────

model Approval {
  id              String          @id @default(uuid())
  status          ApprovalStatus  @default(PENDING)
  comments        String?
  createdAt       DateTime        @default(now()) @map("created_at")
  decidedAt       DateTime?       @map("decided_at")

  approverId      String          @map("approver_id")
  approver        User            @relation(fields: [approverId], references: [id])

  changeRequestId String          @map("change_request_id")
  changeRequest   ChangeRequest   @relation(fields: [changeRequestId], references: [id])

  @@index([changeRequestId])
  @@index([approverId])
  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Audit Log ──────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  entity      String
  entityId    String   @map("entity_id")
  action      String
  field       String?
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
